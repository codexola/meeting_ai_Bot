# Production (Vercel: https://meeting-ai-bot.vercel.app)
# Set these in Vercel → Project → Settings → Environment Variables
NEXT_PUBLIC_API_URL=http://103.179.45.111:8000
NEXT_PUBLIC_WS_URL=ws://103.179.45.111:8000

# VPS-hosted frontend (optional): when running start-frontend.bat on the VPS,
# keep NEXT_PUBLIC_API_URL=http://127.0.0.1:8000 — the Next.js server proxies
# /api to the local backend. Use http://YOUR_VPS_IP:3000 from other devices.

# Note: HTTPS Vercel cannot use ws:// (mixed content). The app uses HTTP polling
# for live updates. For WebSocket, add TLS on the VPS and set NEXT_PUBLIC_WS_URL=wss://...
