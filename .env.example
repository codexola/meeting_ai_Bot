# Python backend on your VPS (used by Next.js rewrites at build/runtime on Vercel)
NEXT_PUBLIC_API_URL=http://103.179.45.111:8000

# WebSocket — browser connects directly (NOT proxied by Vercel).
# Required when frontend is on HTTPS (Vercel). Use wss:// if you have TLS on the backend.
# For HTTP-only VPS during testing, use ws:// only with http:// frontend (not Vercel production).
NEXT_PUBLIC_WS_URL=ws://103.179.45.111:8000
